{
  "name": "wiremonitor",
  "version": "0.1.0",
  "description": "Network traffic web dashboard. Local-first, real-time, no telemetry.",
  "type": "module",
  "bin": {
    "wm": "dist/server.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "homepage": "https://github.com/psandis/wiremonitor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/psandis/wiremonitor.git"
  },
  "keywords": [
    "network",
    "monitor",
    "dashboard",
    "security",
    "sqlite",
    "traffic",
    "sse"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "better-sqlite3": "12.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
